generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  subdomain    String   @unique
  whatsapp     String
  document     String?
  logo_url     String?
  banner_url   String?
  instagram_url String?
  facebook_url String?
  address      String?
  address_street   String?
  address_number   String?
  address_complement String?
  address_district String?
  address_city     String?
  address_state    String?  @db.Char(2)
  address_zip      String?
  show_address Boolean  @default(true)
  template_id  String   @default("minimal")
  about_text   String?  @db.Text
  footer_text  String?  @db.Text
  primary_color    String  @default("#000000")
  featured_limit   Int     @default(4)
  bestseller_limit Int     @default(8)
  business_hours   Json?
  payment_methods  Json?
  policies         Json?
  card_fees        Json?
  status           String   @default("active")
  trial_days       Int      @default(30)
  trial_starts_at  DateTime?
  trial_ends_at    DateTime?
  subscription_amount Decimal @default(0) @db.Decimal(10, 2)
  setup_completed_at DateTime?
  created_at       DateTime @default(now())
  updated_at   DateTime @updatedAt

  users           User[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  stock_movements StockMovement[]
  finance              Finance[]
  accounts_receivable  AccountReceivable[]
  accounts_payable     AccountPayable[]
  customers            Customer[]
  suppliers       Supplier[]
  setup_invites   SetupInvite[]
  quotes          Quote[]
  sellers         Seller[]
  goals           Goal[]

  @@map("tenants")
}

model SetupInvite {
  id                  Int       @id @default(autoincrement())
  tenant_id           Int?
  token               String    @unique
  store_name          String
  subdomain           String
  whatsapp            String
  owner_name          String?
  owner_email         String?
  trial_days          Int       @default(30)
  subscription_amount Decimal   @default(0) @db.Decimal(10, 2)
  invite_expires_at   DateTime
  used_at             DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenant_id], references: [id])

  @@index([subdomain])
  @@map("setup_invites")
}

model User {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  name       String
  email      String   @unique
  password   String
  role       String   @default("admin")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenant_id], references: [id])
  preferences   UserPreference[]
  reset_tokens  PasswordResetToken[]

  @@map("users")
}

model Category {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id])
  products Product[]

  @@map("categories")
}

model Product {
  id             Int       @id @default(autoincrement())
  tenant_id      Int
  category_id    Int?
  name           String
  sku            String?
  barcode        String?
  description    String?   @db.Text
  price          Decimal   @db.Decimal(10, 2)
  cost_price     Decimal   @default(0) @db.Decimal(10, 2)
  discount_price Decimal?  @db.Decimal(10, 2)
  stock_quantity Int       @default(0)
  image_url      String?
  images         Json?
  expiry_date    DateTime? @db.Date
  type           String    @default("sale")
  is_active      Boolean   @default(true)
  is_featured    Boolean   @default(false)
  variations     Json?
  attributes     Json?
  skus           Json?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  tenant          Tenant          @relation(fields: [tenant_id], references: [id])
  category        Category?       @relation(fields: [category_id], references: [id])
  order_items     OrderItem[]
  stock_movements StockMovement[]
  history         ProductHistory[]

  @@map("products")
}

model ProductHistory {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  product_id Int
  field      String
  old_value  String?  @db.Text
  new_value  String?  @db.Text
  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([tenant_id])
  @@map("product_history")
}

model Order {
  id               Int       @id @default(autoincrement())
  tenant_id        Int
  seller_id        Int?
  seller_name      String?
  customer_name    String?
  customer_phone   String?
  customer_address String?
  total_amount     Decimal   @db.Decimal(10, 2)
  gross_amount     Decimal?  @db.Decimal(10, 2)
  discount_amount  Decimal?  @db.Decimal(10, 2)
  fee_amount       Decimal?  @db.Decimal(10, 2)
  status           String    @default("pending")
  payment_method   String?
  cancelled_by     String?
  cancel_reason    String?
  cancelled_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant Tenant      @relation(fields: [tenant_id], references: [id])
  seller Seller?     @relation(fields: [seller_id], references: [id], onDelete: SetNull)
  items  OrderItem[]

  @@map("orders")
}

model Seller {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  name            String
  email           String?
  phone           String?
  document        String?
  commission_rate Decimal  @default(0) @db.Decimal(5, 2)
  is_active       Boolean  @default(true)
  notes           String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenant_id], references: [id])
  orders Order[]

  @@map("sellers")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  unit_price Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [order_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

model StockMovement {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  product_id Int
  quantity   Int
  type       String
  reason     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@map("stock_movements")
}

model Finance {
  id             Int      @id @default(autoincrement())
  tenant_id      Int
  type           String
  description    String
  amount         Decimal  @db.Decimal(10, 2)
  gross_amount   Decimal? @db.Decimal(10, 2)
  fee_amount     Decimal? @db.Decimal(10, 2)
  discount_amount Decimal? @db.Decimal(10, 2)
  date           DateTime @db.Date
  category       String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("finance")
}

model AccountReceivable {
  id            Int       @id @default(autoincrement())
  tenant_id     Int
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  due_date      DateTime  @db.Date
  received_date DateTime? @db.Date
  status        String    @default("pending")
  category      String?
  customer_name String?
  notes         String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("accounts_receivable")
}

model AccountPayable {
  id            Int       @id @default(autoincrement())
  tenant_id     Int
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  due_date      DateTime  @db.Date
  paid_date     DateTime? @db.Date
  status        String    @default("pending")
  category      String?
  supplier_name String?
  notes         String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("accounts_payable")
}

model Customer {
  id           Int      @id @default(autoincrement())
  tenant_id    Int
  name         String
  email        String?
  phone        String?
  document     String?
  address      String?
  notes        String?  @db.Text
  credit_limit Decimal? @db.Decimal(10, 2)
  risk_flag    Boolean  @default(false)
  risk_reason  String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenant_id], references: [id])
  debts          CustomerDebt[]
  customer_notes CustomerNote[]

  @@map("customers")
}

model CustomerDebt {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  customer_id Int
  description String
  amount      Decimal   @db.Decimal(10, 2)
  due_date    DateTime? @db.Date
  paid_at     DateTime?
  status      String    @default("open")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([customer_id])
  @@map("customer_debts")
}

model CustomerNote {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  customer_id Int
  body        String   @db.Text
  created_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@map("customer_notes")
}

model Supplier {
  id             Int      @id @default(autoincrement())
  tenant_id      Int
  name           String
  category       String
  contact_person String?
  phone          String?
  address        String?
  notes          String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("suppliers")
}

model Quote {
  id                 Int         @id @default(autoincrement())
  tenant_id          Int
  number             Int
  customer_id        Int?
  customer_name      String
  customer_phone     String?
  customer_email     String?
  subtotal           Decimal     @db.Decimal(10, 2)
  discount_type      String      @default("percent")
  discount_value     Decimal     @default(0) @db.Decimal(10, 2)
  total_amount       Decimal     @db.Decimal(10, 2)
  validity_days      Int         @default(7)
  notes              String?     @db.Text
  status             String      @default("open")
  converted_order_id Int?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  tenant Tenant      @relation(fields: [tenant_id], references: [id])
  items  QuoteItem[]

  @@unique([tenant_id, number])
  @@map("quotes")
}

model QuoteItem {
  id         Int      @id @default(autoincrement())
  quote_id   Int
  product_id Int?
  name       String
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)

  quote Quote @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model Goal {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  title         String
  description   String?  @db.Text
  type          String
  period        String
  target_value  Decimal  @db.Decimal(14, 2)
  current_value Decimal  @default(0) @db.Decimal(14, 2)
  start_date    DateTime @db.Date
  end_date      DateTime @db.Date
  status        String   @default("active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("goals")
}

model UserPreference {
  id         Int      @id @default(autoincrement())
  user_id    Int
  pref_key   String
  value      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, pref_key])
  @@map("user_preferences")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("password_reset_tokens")
}
