generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  subdomain    String   @unique
  whatsapp     String
  document     String?
  logo_url     String?
  banner_url   String?
  instagram_url String?
  facebook_url String?
  address      String?
  address_street   String?
  address_number   String?
  address_complement String?
  address_district String?
  address_city     String?
  address_state    String?  @db.Char(2)
  address_zip      String?
  show_address Boolean  @default(true)
  template_id  String   @default("minimal")
  about_text   String?  @db.Text
  footer_text  String?  @db.Text
  primary_color    String  @default("#000000")
  featured_limit   Int     @default(4)
  bestseller_limit Int     @default(8)
  business_hours   Json?
  payment_methods  Json?
  policies         Json?
  card_fees              Json?
  pass_fee_to_customer   Boolean  @default(false)
  max_installments       Int      @default(12)
  enabled_brands         Json?
  pass_fee_by_method     Json?
  terminal_config        Json?
  status                 String   @default("active")
  trial_days       Int      @default(30)
  trial_starts_at  DateTime?
  trial_ends_at    DateTime?
  subscription_amount Decimal @default(0) @db.Decimal(10, 2)
  setup_completed_at DateTime?

  // --- Dados fiscais ---
  razao_social         String?
  inscricao_estadual   String?
  inscricao_municipal  String?
  cnae_fiscal          String?
  tax_regime           String   @default("simples_nacional")
  crt                  Int      @default(1)

  // NFC-e
  nfce_environment     String   @default("homologacao")
  nfce_series          Int      @default(1)
  nfce_next_number     Int      @default(1)
  nfce_csc_id          String?
  nfce_csc_token       String?
  nfce_cert_path       String?
  nfce_cert_password   String?

  created_at       DateTime @default(now())
  updated_at   DateTime @updatedAt

  users           User[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  stock_movements StockMovement[]
  finance              Finance[]
  accounts_receivable  AccountReceivable[]
  accounts_payable     AccountPayable[]
  customers            Customer[]
  suppliers       Supplier[]
  setup_invites   SetupInvite[]
  quotes          Quote[]
  sellers         Seller[]
  goals           Goal[]
  services        Service[]
  loyalty_program LoyaltyProgram?
  order_actions   OrderAction[]
  service_orders         ServiceOrder[]
  service_order_actions  ServiceOrderAction[]
  nfce_invoices          NfceInvoice[]
  whatsapp_workspace     WhatsappWorkspace?
  terminal_transactions  TerminalTransaction[]

  @@map("tenants")
}

model SetupInvite {
  id                  Int       @id @default(autoincrement())
  tenant_id           Int?
  token               String    @unique
  store_name          String
  subdomain           String
  whatsapp            String
  owner_name          String?
  owner_email         String?
  trial_days          Int       @default(30)
  subscription_amount Decimal   @default(0) @db.Decimal(10, 2)
  invite_expires_at   DateTime
  used_at             DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenant_id], references: [id])

  @@index([subdomain])
  @@map("setup_invites")
}

model User {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  name       String
  email      String   @unique
  password   String
  role       String   @default("admin")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenant_id], references: [id])
  preferences   UserPreference[]
  reset_tokens  PasswordResetToken[]

  @@map("users")
}

model Category {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id])
  products Product[]

  @@map("categories")
}

model Product {
  id             Int       @id @default(autoincrement())
  tenant_id      Int
  category_id    Int?
  name           String
  sku            String?
  barcode        String?
  description    String?   @db.Text
  price          Decimal   @db.Decimal(10, 2)
  cost_price     Decimal   @default(0) @db.Decimal(10, 2)
  discount_price Decimal?  @db.Decimal(10, 2)
  stock_quantity Int       @default(0)
  image_url      String?
  images         Json?
  expiry_date    DateTime? @db.Date
  type           String    @default("sale")
  is_active      Boolean   @default(false)
  is_featured    Boolean   @default(false)
  variations     Json?
  attributes     Json?
  skus           Json?

  // --- Dados fiscais ---
  ncm                String?  @db.VarChar(8)
  cest               String?  @db.VarChar(7)
  cfop               String?  @default("5102") @db.VarChar(4)
  origem             Int      @default(0)
  unidade_comercial  String   @default("UN")
  unidade_tributavel String   @default("UN")
  csosn              String?  @default("102")
  cst_icms           String?
  icms_aliquota      Decimal? @db.Decimal(5, 2)
  pis_cst            String?
  pis_aliquota       Decimal? @db.Decimal(5, 2)
  cofins_cst         String?
  cofins_aliquota    Decimal? @db.Decimal(5, 2)

  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  tenant          Tenant          @relation(fields: [tenant_id], references: [id])
  category        Category?       @relation(fields: [category_id], references: [id])
  order_items     OrderItem[]
  stock_movements StockMovement[]
  history         ProductHistory[]
  service_order_parts ServiceOrderPart[]

  @@map("products")
}

model Service {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  unit        String   @default("unidade")
  category    String   @default("Geral")
  is_active   Boolean  @default(true)
  image_url   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenant_id], references: [id])
  order_services OrderService[]
  quote_services QuoteService[]

  @@index([tenant_id])
  @@map("services")
}

model OrderService {
  id         Int     @id @default(autoincrement())
  order_id   Int
  service_id Int
  name       String
  unit_price Decimal @db.Decimal(10, 2)
  quantity   Int     @default(1)

  order   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  service Service @relation(fields: [service_id], references: [id])

  @@map("order_services")
}

model QuoteService {
  id         Int     @id @default(autoincrement())
  quote_id   Int
  service_id Int
  name       String
  unit_price Decimal @db.Decimal(10, 2)
  quantity   Int     @default(1)
  total      Decimal @db.Decimal(10, 2)

  quote   Quote   @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  service Service @relation(fields: [service_id], references: [id])

  @@map("quote_services")
}

model ProductHistory {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  product_id Int
  field      String
  old_value  String?  @db.Text
  new_value  String?  @db.Text
  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([tenant_id])
  @@map("product_history")
}

model Order {
  id               Int       @id @default(autoincrement())
  tenant_id        Int
  seller_id        Int?
  seller_name      String?
  customer_id      Int?
  customer_name    String?
  customer_phone   String?
  customer_address String?
  total_amount     Decimal   @db.Decimal(10, 2)
  gross_amount     Decimal?  @db.Decimal(10, 2)
  discount_amount  Decimal?  @db.Decimal(10, 2)
  fee_amount       Decimal?  @db.Decimal(10, 2)
  status           String    @default("pending")
  order_type       String    @default("products")
  payment_method   String?
  client_sale_id   String?   @unique
  cancelled_by     String?
  cancel_reason    String?
  cancelled_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant                Tenant                @relation(fields: [tenant_id], references: [id])
  seller                Seller?               @relation(fields: [seller_id], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  services              OrderService[]
  actions               OrderAction[]
  nfce_invoice          NfceInvoice?
  terminal_transactions TerminalTransaction[]

  @@map("orders")
}

model TerminalTransaction {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  order_id           Int?
  provider           String // rede | stone | mercadopago | cielo | pagseguro
  environment        String // sandbox | production
  status             String    @default("pending") // pending | approved | denied | cancelled | error
  external_id        String? // id retornado pela adquirente
  nsu                String?
  authorization_code String?
  brand              String?
  mode               String? // credit | debit
  installments       Int       @default(1)
  amount             Decimal   @db.Decimal(10, 2)
  fee_amount         Decimal?  @db.Decimal(10, 2)
  device_id          String? // aparelho físico (Mercado Pago Point)
  raw_response       Json?
  error_message      String?   @db.Text
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  order  Order? @relation(fields: [order_id], references: [id])

  @@index([tenant_id])
  @@index([order_id])
  @@index([status])
  @@map("terminal_transactions")
}

model NfceInvoice {
  id               Int       @id @default(autoincrement())
  tenant_id        Int
  order_id         Int       @unique
  status           String    @default("pending") // pending | processing | authorized | rejected | error | cancelled
  environment      String
  series           Int
  number           Int
  access_key       String?   @unique
  protocol         String?
  authorized_at    DateTime?
  rejection_code   String?
  rejection_reason String?   @db.Text
  xml_path         String?
  danfe_path       String?
  qrcode_url       String?   @db.Text
  attempts         Int       @default(0)
  last_attempt_at  DateTime?

  // Cancelamento (evento 110111)
  cancel_protocol  String?
  cancel_reason    String?   @db.Text
  cancelled_at     DateTime?
  cancel_xml_path  String?

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  order  Order  @relation(fields: [order_id], references: [id])

  @@index([tenant_id])
  @@index([status])
  @@map("nfce_invoices")
}

model OrderAction {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  order_id   Int
  action     String
  actor      String?
  note       String?  @db.Text
  meta       Json?
  created_at DateTime @default(now())

  order  Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([order_id])
  @@index([tenant_id])
  @@map("order_actions")
}

model Seller {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  name            String
  email           String?
  phone           String?
  document        String?
  commission_rate Decimal  @default(0) @db.Decimal(5, 2)
  is_active       Boolean  @default(true)
  notes           String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenant_id], references: [id])
  orders Order[]
  service_orders ServiceOrder[]

  @@map("sellers")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  unit_price Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model StockMovement {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  product_id Int
  quantity   Int
  type       String
  reason     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id])
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model Finance {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  type            String
  description     String
  amount          Decimal  @db.Decimal(10, 2)
  gross_amount    Decimal? @db.Decimal(10, 2)
  fee_amount      Decimal? @db.Decimal(10, 2)
  discount_amount Decimal? @db.Decimal(10, 2)
  date            DateTime @db.Date
  category        String?
  payment_method  String?
  source          String?
  order_id        Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("finance")
}

model AccountReceivable {
  id            Int       @id @default(autoincrement())
  tenant_id     Int
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  due_date      DateTime  @db.Date
  received_date DateTime? @db.Date
  status        String    @default("pending")
  category      String?
  customer_name String?
  notes         String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("accounts_receivable")
}

model AccountPayable {
  id            Int       @id @default(autoincrement())
  tenant_id     Int
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  due_date      DateTime  @db.Date
  paid_date     DateTime? @db.Date
  status        String    @default("pending")
  category      String?
  supplier_name String?
  notes         String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("accounts_payable")
}

model Customer {
  id           Int      @id @default(autoincrement())
  tenant_id    Int
  name         String
  email        String?
  phone        String?
  document     String?
  address      String?
  notes        String?  @db.Text
  credit_limit Decimal? @db.Decimal(10, 2)
  birth_date   DateTime?
  risk_flag    Boolean  @default(false)
  risk_reason  String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenant_id], references: [id])
  debts          CustomerDebt[]
  customer_notes CustomerNote[]
  point_entries  CustomerPoint[]
  redemptions    PointRedemption[]

  @@map("customers")
}

model CustomerDebt {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  customer_id Int
  description String
  amount      Decimal   @db.Decimal(10, 2)
  due_date    DateTime? @db.Date
  paid_at     DateTime?
  status      String    @default("open")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([customer_id])
  @@map("customer_debts")
}

model CustomerNote {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  customer_id Int
  body        String   @db.Text
  created_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@map("customer_notes")
}

model Supplier {
  id             Int      @id @default(autoincrement())
  tenant_id      Int
  name           String
  category       String
  contact_person String?
  phone          String?
  whatsapp       String?
  email          String?
  website        String?
  cnpj           String?
  address        String?
  city           String?
  state          String?
  payment_terms  String?
  notes          String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("suppliers")
}

model Quote {
  id                 Int         @id @default(autoincrement())
  tenant_id          Int
  number             Int
  customer_id        Int?
  customer_name      String
  customer_phone     String?
  customer_email     String?
  subtotal           Decimal     @db.Decimal(10, 2)
  discount_type      String      @default("percent")
  discount_value     Decimal     @default(0) @db.Decimal(10, 2)
  total_amount       Decimal     @db.Decimal(10, 2)
  validity_days      Int         @default(7)
  notes              String?     @db.Text
  status             String      @default("open")
  converted_order_id Int?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  tenant   Tenant         @relation(fields: [tenant_id], references: [id])
  items    QuoteItem[]
  services QuoteService[]

  @@unique([tenant_id, number])
  @@map("quotes")
}

model QuoteItem {
  id         Int      @id @default(autoincrement())
  quote_id   Int
  product_id Int?
  name       String
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)

  quote Quote @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model ServiceOrder {
  id                    Int       @id @default(autoincrement())
  tenant_id             Int
  number                Int

  customer_id           Int?
  customer_name         String
  customer_phone        String?

  equipment_category    String
  equipment_type        String?
  equipment_brand       String?
  equipment_model       String?
  equipment_serial      String?
  equipment_accessories String?   @db.Text

  seller_id             Int?
  technician_name       String?

  status                String    @default("aberta")

  service_value         Decimal   @default(0) @db.Decimal(10, 2)
  parts_total           Decimal   @default(0) @db.Decimal(10, 2)
  total_amount          Decimal   @default(0) @db.Decimal(10, 2)

  observations          String?   @db.Text

  invoiced_order_id     Int?
  invoiced_at           DateTime?

  cancelled_by          String?
  cancel_reason         String?
  cancelled_at          DateTime?

  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  tenant           Tenant                      @relation(fields: [tenant_id], references: [id])
  seller           Seller?                     @relation(fields: [seller_id], references: [id], onDelete: SetNull)
  checklist_items  ServiceOrderChecklistItem[]
  parts            ServiceOrderPart[]
  photos           ServiceOrderPhoto[]
  actions          ServiceOrderAction[]

  @@unique([tenant_id, number])
  @@index([tenant_id])
  @@index([tenant_id, status])
  @@map("service_orders")
}

model ServiceOrderChecklistItem {
  id                Int      @id @default(autoincrement())
  tenant_id         Int
  service_order_id  Int
  label             String
  answer            String?
  observation       String?  @db.Text
  position          Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  service_order ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)

  @@index([service_order_id])
  @@index([tenant_id])
  @@map("service_order_checklist_items")
}

model ServiceOrderPart {
  id                Int      @id @default(autoincrement())
  service_order_id  Int
  product_id        Int?
  name              String
  quantity          Int      @default(1)
  unit_price        Decimal  @db.Decimal(10, 2)
  total             Decimal  @db.Decimal(10, 2)
  created_at        DateTime @default(now())

  service_order ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)
  product       Product?     @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([service_order_id])
  @@map("service_order_parts")
}

model ServiceOrderPhoto {
  id                Int      @id @default(autoincrement())
  tenant_id         Int
  service_order_id  Int
  url               String
  caption           String?
  kind              String   @default("intake")
  created_at        DateTime @default(now())

  service_order ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)

  @@index([service_order_id])
  @@index([tenant_id])
  @@map("service_order_photos")
}

model ServiceOrderAction {
  id                Int      @id @default(autoincrement())
  tenant_id         Int
  service_order_id  Int
  action            String
  from_status       String?
  to_status         String?
  actor             String?
  note              String?  @db.Text
  meta              Json?
  created_at        DateTime @default(now())

  service_order ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)
  tenant        Tenant       @relation(fields: [tenant_id], references: [id])

  @@index([service_order_id])
  @@index([tenant_id])
  @@map("service_order_actions")
}

model Goal {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  title         String
  description   String?  @db.Text
  type          String
  period        String
  target_value  Decimal  @db.Decimal(14, 2)
  current_value Decimal  @default(0) @db.Decimal(14, 2)
  start_date    DateTime @db.Date
  end_date      DateTime @db.Date
  status        String   @default("active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("goals")
}

model UserPreference {
  id         Int      @id @default(autoincrement())
  user_id    Int
  pref_key   String
  value      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, pref_key])
  @@map("user_preferences")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("password_reset_tokens")
}

// ─── Loyalty / Fidelidade ─────────────────────────────────────────────────────

model LoyaltyProgram {
  id                  Int      @id @default(autoincrement())
  tenant_id           Int      @unique
  is_active           Boolean  @default(true)
  name                String   @default("Programa de Fidelidade")
  // quantos reais equivalem a 1 ponto  (ex: 10.00 → a cada R$10 ganha 1 ponto)
  spend_per_point     Decimal  @db.Decimal(10, 2) @default(10)
  // validade dos pontos em dias (0 = sem validade)
  points_expiry_days  Int      @default(0)
  // data de início da temporada atual
  season_start        DateTime?
  // data de fim da temporada atual (null = sem fim definido)
  season_end          DateTime?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  tenant  Tenant           @relation(fields: [tenant_id], references: [id])
  rewards LoyaltyReward[]

  @@map("loyalty_programs")
}

model LoyaltyReward {
  id          Int      @id @default(autoincrement())
  program_id  Int
  tenant_id   Int
  name        String
  // tipo: "discount" | "product"
  type        String
  // se discount: valor do desconto em R$ ou %
  discount_value   Decimal? @db.Decimal(10, 2)
  discount_type    String?  // "fixed" | "percent"
  // se product: produto do estoque que será deduzido
  product_id       Int?
  product_qty      Int?     @default(1)
  // custo em pontos para resgatar
  points_cost Int
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  program     LoyaltyProgram    @relation(fields: [program_id], references: [id], onDelete: Cascade)
  redemptions PointRedemption[]

  @@index([tenant_id])
  @@map("loyalty_rewards")
}

model CustomerPoint {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  customer_id Int
  order_id    Int?
  // positivo = ganhou pontos; negativo = resgatou pontos
  delta       Int
  balance_after Int
  description String?
  expires_at  DateTime?
  created_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([tenant_id])
  @@map("customer_points")
}

model PointRedemption {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  customer_id Int
  reward_id   Int
  order_id    Int?
  points_used Int
  created_at  DateTime @default(now())

  customer Customer       @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  reward   LoyaltyReward  @relation(fields: [reward_id], references: [id])

  @@index([customer_id])
  @@index([tenant_id])
  @@map("point_redemptions")
}

model WhatsappWorkspace {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int      @unique
  is_enabled         Boolean  @default(false)
  provider           String   @default("evolution")
  evolution_base_url String?
  evolution_api_key  String?  @db.Text
  evolution_instance String?
  webhook_secret     String?
  fallback_phone     String?
  settings           Json?
  menus              Json?
  templates          Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant        Tenant                  @relation(fields: [tenant_id], references: [id])
  agents        WhatsappAgent[]
  conversations WhatsappConversation[]

  @@map("whatsapp_workspaces")
}

model WhatsappAgent {
  id                   Int      @id @default(autoincrement())
  workspace_id         Int
  name                 String
  department           String   @default("sales")
  role                 String   @default("agent")
  phone                String?
  email                String?
  is_active            Boolean  @default(true)
  is_online            Boolean  @default(true)
  can_receive_transfer Boolean  @default(true)
  max_concurrent_chats Int      @default(3)
  priority             Int      @default(0)
  notes                String?  @db.Text
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  workspace      WhatsappWorkspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  conversations  WhatsappConversation[]

  @@index([workspace_id, department, is_active, is_online])
  @@map("whatsapp_agents")
}

model WhatsappConversation {
  id                   Int      @id @default(autoincrement())
  workspace_id         Int
  remote_jid           String
  phone                String
  customer_name        String?
  status               String   @default("bot")
  current_menu         String   @default("main")
  department           String?
  assigned_agent_id    Int?
  queue_position       Int?
  last_message_preview String?  @db.Text
  last_inbound_at      DateTime?
  last_outbound_at     DateTime?
  closed_reason        String?
  metadata             Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  workspace       WhatsappWorkspace   @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  assigned_agent  WhatsappAgent?      @relation(fields: [assigned_agent_id], references: [id], onDelete: SetNull)
  messages        WhatsappMessageLog[]

  @@unique([workspace_id, remote_jid])
  @@index([workspace_id, status, department])
  @@index([workspace_id, assigned_agent_id])
  @@map("whatsapp_conversations")
}

model WhatsappMessageLog {
  id                Int      @id @default(autoincrement())
  conversation_id   Int
  direction         String
  message_type      String   @default("text")
  body              String?  @db.Text
  external_message_id String?
  payload           Json?
  created_at        DateTime @default(now())

  conversation WhatsappConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@map("whatsapp_message_logs")
}
