{
  "name": "boxsys-pdv",
  "productName": "BoxSys PDV",
  "version": "1.0.0",
  "description": "Terminal de Vendas BoxSys — Aplicativo Desktop",
  "main": "main.cjs",
  "author": "BoxSys",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.boxsys.pdv",
    "productName": "BoxSys PDV",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "printer.cjs",
      "setup.html",
      "offline.html",
      "printer-config.html",
      "icon.png",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@serialport/**/*",
      "node_modules/serialport/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "artifactName": "BoxSysPDV-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "BoxSys PDV"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.business",
      "artifactName": "BoxSysPDV.dmg"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "category": "Office",
      "artifactName": "BoxSysPDV.AppImage"
    }
  },
  "dependencies": {
    "node-thermal-printer": "^4.6.0",
    "serialport": "^13.0.0"
  }
}
